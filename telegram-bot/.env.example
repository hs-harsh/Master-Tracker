# ── Required ──────────────────────────────────────────────────────────────────

# Your Telegram bot token — get it from @BotFather on Telegram
TELEGRAM_TOKEN=your-telegram-bot-token-here

# Your Anthropic API key — get it from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────

# GitHub repo URL for the investment-tracker project (cloned on startup).
# Defaults to Portfolio-Tracker if not set.
GITHUB_REPO=https://github.com/hs-harsh/Portfolio-Tracker.git

# GitHub personal access token for private repos (leave empty for public).
GITHUB_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow anyone. Find your ID by messaging @userinfobot on Telegram.
ALLOWED_USER_IDS=123456789,987654321

# Claude model to use. Defaults to claude-sonnet-4-6.
CLAUDE_MODEL=claude-sonnet-4-6
